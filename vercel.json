{
  "routes": [
    {
      "src": "^/dia2/?$",
      "dest": "/index-dia2.html"
    },
    {
      "src": "^/dia2/athletes/?$",
      "dest": "/athletes-dia2.html"
    },
    {
      "src": "^/dia2/ranking/?$",
      "dest": "/ranking-dia2.html"
    },
    {
      "src": "^/dia2/goleadores/?$",
      "dest": "/goleadores-dia2.html"
    },
    {
      "src": "^/dia2/garcons/?$",
      "dest": "/garcons-dia2.html"
    },
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "^/athletes/?$",
      "dest": "/athletes.html"
    },
    {
      "src": "^/ranking/?$",
      "dest": "/ranking.html"
    },
    {
      "src": "^/goleadores/?$",
      "dest": "/goleadores.html"
    },
    {
      "src": "^/garcons/?$",
      "dest": "/garcons.html"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/api/$1"
    }
  ]
}
