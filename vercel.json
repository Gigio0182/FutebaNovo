{
  "routes": [
    {
      "src": "^/domingo/?$",
      "dest": "/index-domingo.html"
    },
    {
      "src": "^/domingo/athletes/?$",
      "dest": "/athletes-domingo.html"
    },
    {
      "src": "^/domingo/ranking/?$",
      "dest": "/ranking-domingo.html"
    },
    {
      "src": "^/domingo/goleadores/?$",
      "dest": "/goleadores-domingo.html"
    },
    {
      "src": "^/domingo/garcons/?$",
      "dest": "/garcons-domingo.html"
    },
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "^/athletes/?$",
      "dest": "/athletes.html"
    },
    {
      "src": "^/ranking/?$",
      "dest": "/ranking.html"
    },
    {
      "src": "^/goleadores/?$",
      "dest": "/goleadores.html"
    },
    {
      "src": "^/garcons/?$",
      "dest": "/garcons.html"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/api/$1"
    }
  ]
}
