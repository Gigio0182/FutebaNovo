{
  "routes": [
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "^/athletes/?$",
      "dest": "/athletes.html"
    },
    {
      "src": "^/ranking/?$",
      "dest": "/ranking.html"
    },
    {
      "src": "^/goleadores/?$",
      "dest": "/goleadores.html"
    },
    {
      "src": "^/garcons/?$",
      "dest": "/garcons.html"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/api/$1"
    }
  ]
}
