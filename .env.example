# Ambiente alvo para variaveis sufixadas (opcional)
# Exemplos: production, preview, qa
FIREBASE_ENVIRONMENT=preview

# Fluxo recomendado na Vercel:
# - Production (main): use FIREBASE_SERVICE_ACCOUNT_BASE64_PRODUCTION
# - Preview (branch-DEV e branch-QA): use FIREBASE_SERVICE_ACCOUNT_BASE64_PREVIEW
FIREBASE_SERVICE_ACCOUNT_BASE64_PRODUCTION=
FIREBASE_SERVICE_ACCOUNT_BASE64_PREVIEW=

# Opcional: variaveis para ambientes customizados (ex.: qa)
# FIREBASE_SERVICE_ACCOUNT_BASE64_QA=

# Fallback legado (ainda suportado)
# FIREBASE_SERVICE_ACCOUNT_BASE64=

APP_ADMIN_PASSWORD=
APP_AUTH_SECRET=
